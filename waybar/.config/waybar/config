{
    "layer": "top",
    "position": "top",
    "margin-bottom": 0,
    "modules-left": [
        "hyprland/workspaces",
        "tray",
        "hyprland/window",
    ],
    "modules-center": [
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "clock",
    ],
    "tray": {
        "icon-size": 24,
        "spacing": 10
    },
    "hyprland/window": {
        "format": " {}",
        "rewrite": {
            "(\\d\\. )?(.*) - Brave": "<span color=\"#56b6c2\"></span> $2 ",
            " *Alacritty *": "<span color=\"#56b6c2\"></span>",
        },
        "separate-outputs": false
    },
    "hyprland/submap": {
        "format": "✌️ {}",
        "max-length": 8,
        "tooltip": true
    },
    /*static const char *tags[] = { "", "", "", "", "", "", "", "", ""};*/
    "hyprland/workspaces": {
        "separate-outputs": true,
        "format": "{name}",
        "ignore-workspaces": [
            "20"
        ],
    },
    "network": {
        "interface": "enp6s0",
        "tooltip-format-ethernet": "{ifname} ",
        "interval": 2,
        "format": "{ipaddr}  <span color=\"#57A143\">↑{bandwidthUpBytes:>5}</span>  <span color=\"#ffA143\">↓{bandwidthDownBytes:>5}</span> "
    },

    "network2": {
        "interface": "enp6s0",
        "tooltip-format-ethernet": "{ifname} ",
        "interval": 2,
        "format": "{ipaddr} <span color=\"#56b6c2\">↑{bandwidthUpBytes}</span>   ↓{bandwidthDownBytes}" ,
    },
    "battery": {
        "bat": "BAT0",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-icons": ["  ", "  ", "  ", "  ", "  "],
        "max-length": 25
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", ""]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol"
    },
    "clock": {
        //"format": "<span color=\"#56b6c2\"></span> {:%H:%M}",
        "format": "{:%B %d %H:%M}",
        "interval": 60,
        "tooltip": true,
        "tooltip-format": "{:%d %B %H:%M}"
    }
}
